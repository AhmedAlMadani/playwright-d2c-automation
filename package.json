{
  "name": "playwright-d2c-automation",
  "version": "1.0.0",
  "description": "Production-quality D2C QA automation framework using Playwright + TypeScript",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:e2e": "playwright test src/tests/e2e",
    "test:api": "playwright test src/tests/api --project=chromium",
    "test:negative": "playwright test src/tests/negative --project=chromium",
    "test:edge": "playwright test src/tests/edge --project=chromium",
    "test:headed": "playwright test --headed --workers=1",
    "test:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "start:mock": "node mock-app/server.js"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "d2c",
    "subscription"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.0",
    "@supabase/supabase-js": "^2.104.1",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "uuid": "^9.0.0"
  }
}
