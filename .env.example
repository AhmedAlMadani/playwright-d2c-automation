# Application base URL (the UI under test)
BASE_URL=http://localhost:3000

# Mock API base URL
API_URL=http://localhost:3001

# Toggle verbose debug logging
DEBUG_MODE=false

# CI flag (set automatically by GitHub Actions)
# CI=true
