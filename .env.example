# ──────────────────────────────────────────────
# D2C Automation Framework – Environment Config
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Application base URL (the UI under test)
BASE_URL=http://localhost:3000

# Mock API base URL (unused when Supabase is active)
API_URL=http://localhost:3001

# Toggle verbose debug logging
DEBUG_MODE=false

# ── Supabase ────────────────────────────────────
# Project URL: Settings → API → Project URL
SUPABASE_URL=https://<project-ref>.supabase.co

# Anon (publishable) key: Settings → API → Project API keys → anon public
# Use this key — NOT the service_role key — for all test operations.
# RLS is assumed disabled for the test project.
SUPABASE_ANON_KEY=<your-anon-key>

# CI flag (set automatically by GitHub Actions)
# CI=true
